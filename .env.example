# ─── Thunder Dashboard — Environment Variables ───────────────────────────────
# Copy this file to .env.local for local development.
# Never commit actual .env files — only this .example is safe to commit.

# Supabase (use staging for local dev)
VITE_SUPABASE_URL=https://staging.thunderpro.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# App URL
VITE_PUBLIC_APP_URL=http://localhost:8080

# Stripe (use test keys for local dev)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
VITE_MAPBOX_TOKEN=your_mapbox_token
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_key

# Development flags
VITE_DISABLE_SUBSCRIPTIONS=true

#RevenueCat Web
VITE_REVENUECAT_WEB_KEY=revenuecat_api_key
